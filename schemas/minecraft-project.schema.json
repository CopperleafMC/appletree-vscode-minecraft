{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.appletree.tools/minecraft-project/v1/schema.json",
  "title": "Appletree Minecraft project profile",
  "description": "Project-local build, validation, launch, and deployment commands consumed by Appletree Minecraft Tools.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "adapter",
    "commands"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "adapter": {
      "type": "string",
      "enum": [
        "script",
        "fabric-gradle",
        "forge-gradle",
        "neoforge-gradle",
        "quilt-gradle"
      ]
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "darwin",
          "linux",
          "win32"
        ]
      },
      "uniqueItems": true
    },
    "architectures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "remoteSupported": {
      "type": "boolean",
      "default": true
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "environment": { "$ref": "#/$defs/command" },
        "buildNative": { "$ref": "#/$defs/command" },
        "build": { "$ref": "#/$defs/command" },
        "test": { "$ref": "#/$defs/command" },
        "launch": { "$ref": "#/$defs/command" },
        "visualMetal": { "$ref": "#/$defs/command" },
        "visualVanilla": { "$ref": "#/$defs/command" },
        "profile": { "$ref": "#/$defs/command" },
        "profileSummary": { "$ref": "#/$defs/command" },
        "usage": { "$ref": "#/$defs/command" }
      },
      "minProperties": 1
    },
    "tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/test"
      }
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "worlds": {
      "$ref": "#/$defs/worlds"
    },
    "deployTargets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deployTarget"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "loader": {
          "type": "string",
          "enum": [
            "fabric",
            "forge",
            "neoforge",
            "quilt",
            "vanilla",
            "unknown"
          ]
        },
        "minecraftVersionProperty": {
          "type": "string"
        },
        "modVersionProperty": {
          "type": "string"
        },
        "artifactGlob": {
          "type": "string"
        },
        "excludeArtifactGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "executable"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "executable": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "longRunning": {
          "type": "boolean",
          "default": false
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "executable"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "executable": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "longRunning": {
          "type": "boolean",
          "default": false
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latestLog": {
          "type": "string"
        },
        "crashReportsGlob": {
          "type": "string"
        },
        "screenshotsGlob": {
          "type": "string"
        }
      }
    },
    "worlds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory"
      ],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": "string"
        }
      }
    },
    "deployTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "destination"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "copy"
          ]
        },
        "destination": {
          "type": "string",
          "minLength": 1
        },
        "cleanMatching": {
          "type": "string"
        },
        "requiresConfirmation": {
          "type": "boolean",
          "default": true
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
