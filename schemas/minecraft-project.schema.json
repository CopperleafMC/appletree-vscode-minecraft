{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.appletree.tools/minecraft-project/v1/schema.json",
  "title": "Appletree Minecraft project profile",
  "description": "Project-local build, validation, launch, and deployment commands consumed by Appletree Minecraft Tools.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "adapter",
    "commands"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "adapter": {
      "type": "string",
      "enum": [
        "script",
        "fabric-gradle",
        "forge-gradle",
        "neoforge-gradle",
        "quilt-gradle"
      ]
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "darwin",
          "linux",
          "win32"
        ]
      },
      "uniqueItems": true
    },
    "architectures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "remoteSupported": {
      "type": "boolean",
      "default": true
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "commands": {
      "type": "object",
      "description": "Project-owned actions. Conventional IDs such as environment, buildNative, build, test, launch, visualPrimary, visualBaseline, profile, profileSummary, and usage receive standard Appletree commands and icons; other IDs remain available as custom actions.",
      "propertyNames": {
        "pattern": "^[a-z][A-Za-z0-9]*$"
      },
      "additionalProperties": { "$ref": "#/$defs/command" },
      "minProperties": 1
    },
    "tests": {
      "type": "array",
      "description": "Deterministic project-owned test lanes published in VS Code Test Explorer.",
      "items": {
        "$ref": "#/$defs/test"
      }
    },
    "evidence": {
      "description": "Optional runtime log, crash-report, and screenshot locations.",
      "$ref": "#/$defs/evidence"
    },
    "worlds": {
      "description": "Enables persistent development-world selection for commands that reference ${world}.",
      "$ref": "#/$defs/worlds"
    },
    "deployTargets": {
      "type": "array",
      "description": "Confirmed local copy targets for the newest deployable artifact.",
      "items": {
        "$ref": "#/$defs/deployTarget"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "loader": {
          "type": "string",
          "enum": [
            "fabric",
            "forge",
            "neoforge",
            "quilt",
            "vanilla",
            "unknown"
          ]
        },
        "minecraftVersionProperty": {
          "type": "string"
        },
        "modVersionProperty": {
          "type": "string"
        },
        "artifactGlob": {
          "type": "string"
        },
        "excludeArtifactGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "executable"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Optional VS Code ThemeIcon ID shown for this action."
        },
        "executable": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "longRunning": {
          "type": "boolean",
          "default": false
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "executable"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "executable": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "longRunning": {
          "type": "boolean",
          "default": false
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latestLog": {
          "type": "string"
        },
        "crashReportsGlob": {
          "type": "string"
        },
        "screenshotsGlob": {
          "type": "string"
        }
      }
    },
    "worlds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory"
      ],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1,
          "description": "Workspace-relative directory containing one folder per development world."
        },
        "default": {
          "type": "string",
          "description": "Initial world used until a workspace selection is made."
        }
      }
    },
    "deployTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "destination"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "copy"
          ]
        },
        "destination": {
          "type": "string",
          "minLength": 1
        },
        "cleanMatching": {
          "type": "string"
        },
        "requiresConfirmation": {
          "type": "boolean",
          "default": true
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
