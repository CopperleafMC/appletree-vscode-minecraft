{
  "name": "appletree-minecraft-tools",
  "displayName": "Appletree Minecraft Tools",
  "description": "Build, validate, launch, and deploy profile-driven Minecraft projects from VS Code.",
  "version": "0.0.1",
  "publisher": "local-prototype",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopperleafMC/appletree-vscode-minecraft.git"
  },
  "homepage": "https://github.com/CopperleafMC/appletree-vscode-minecraft#readme",
  "bugs": {
    "url": "https://github.com/CopperleafMC/appletree-vscode-minecraft/issues"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "minecraft",
    "fabric",
    "forge",
    "neoforge",
    "quilt",
    "gradle",
    "deployment"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Static extension UI remains available, but loading project profiles or executing build, launch, test, and deployment commands requires Workspace Trust.",
      "restrictedConfigurations": [
        "minecraftProjectDeploy.profileFile"
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "minecraftProjectDeploy.refresh",
        "title": "Refresh Project",
        "category": "Appletree Minecraft Tools",
        "icon": "$(refresh)"
      },
      {
        "command": "minecraftProjectDeploy.checkEnvironment",
        "title": "Check Environment",
        "category": "Appletree Minecraft Tools",
        "icon": "$(pass)"
      },
      {
        "command": "minecraftProjectDeploy.buildNative",
        "title": "Build Native Components",
        "category": "Appletree Minecraft Tools",
        "icon": "$(tools)"
      },
      {
        "command": "minecraftProjectDeploy.build",
        "title": "Build Project",
        "category": "Appletree Minecraft Tools",
        "icon": "$(package)"
      },
      {
        "command": "minecraftProjectDeploy.test",
        "title": "Run Project Tests",
        "category": "Appletree Minecraft Tools",
        "icon": "$(beaker)"
      },
      {
        "command": "minecraftProjectDeploy.launch",
        "title": "Launch Development Client",
        "category": "Appletree Minecraft Tools",
        "icon": "$(play)"
      },
      {
        "command": "minecraftProjectDeploy.visualMetal",
        "title": "Launch Metal Visual Variant",
        "category": "Appletree Minecraft Tools",
        "icon": "$(eye)"
      },
      {
        "command": "minecraftProjectDeploy.visualVanilla",
        "title": "Launch Vanilla Visual Baseline",
        "category": "Appletree Minecraft Tools",
        "icon": "$(compare-changes)"
      },
      {
        "command": "minecraftProjectDeploy.profile",
        "title": "Capture Frame-Hitch Profile",
        "category": "Appletree Minecraft Tools",
        "icon": "$(pulse)"
      },
      {
        "command": "minecraftProjectDeploy.profileSummary",
        "title": "Summarize Latest Frame Profile",
        "category": "Appletree Minecraft Tools",
        "icon": "$(graph)"
      },
      {
        "command": "minecraftProjectDeploy.usage",
        "title": "Capture CPU, GPU, and Memory Usage",
        "category": "Appletree Minecraft Tools",
        "icon": "$(dashboard)"
      },
      {
        "command": "minecraftProjectDeploy.deploy",
        "title": "Deploy Mod Artifact...",
        "category": "Appletree Minecraft Tools",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "minecraftProjectDeploy.openProfile",
        "title": "Open Project Profile",
        "category": "Appletree Minecraft Tools",
        "icon": "$(json)"
      },
      {
        "command": "minecraftProjectDeploy.openLatestLog",
        "title": "Open Latest Minecraft Log",
        "category": "Appletree Minecraft Tools",
        "icon": "$(output)"
      },
      {
        "command": "minecraftProjectDeploy.openLatestCrash",
        "title": "Open Latest Crash Report",
        "category": "Appletree Minecraft Tools",
        "icon": "$(bug)"
      },
      {
        "command": "minecraftProjectDeploy.openScreenshots",
        "title": "Open Minecraft Screenshots",
        "category": "Appletree Minecraft Tools",
        "icon": "$(device-camera)"
      }
    ],
    "configuration": {
      "title": "Appletree Minecraft Tools",
      "properties": {
        "minecraftProjectDeploy.profileFile": {
          "type": "string",
          "default": "minecraft-project.json",
          "scope": "resource",
          "description": "Workspace-relative path to the Minecraft project deployment profile."
        },
        "minecraftProjectDeploy.autoRevealOutput": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Reveal the task terminal when a project operation starts."
        },
        "minecraftProjectDeploy.confirmDeploy": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Require confirmation before copying a built mod into a deployment target."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": "minecraft-project.json",
        "url": "./schemas/minecraft-project.schema.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "minecraft-project",
        "required": [
          "operation",
          "projectFolder"
        ],
        "properties": {
          "operation": {
            "type": "string",
            "enum": [
              "environment",
              "buildNative",
              "build",
              "test",
              "launch",
              "visualMetal",
              "visualVanilla",
              "profile",
              "profileSummary",
              "usage"
            ],
            "description": "The profile command to execute."
          },
          "projectFolder": {
            "type": "string",
            "description": "The URI of the workspace folder that owns the project profile."
          }
        },
        "when": "shellExecutionSupported && isWorkspaceTrusted"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "minecraftProjectDeploy",
          "title": "Appletree Minecraft Tools",
          "icon": "media/minecraft-deploy.svg"
        }
      ]
    },
    "views": {
      "minecraftProjectDeploy": [
        {
          "id": "minecraftProjectDeploy.project",
          "name": "Project"
        },
        {
          "id": "minecraftProjectDeploy.actions",
          "name": "Actions"
        },
        {
          "id": "minecraftProjectDeploy.evidence",
          "name": "Runtime Evidence"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "minecraftProjectDeploy.project",
        "contents": "No Minecraft deployment profile was found. Add a `minecraft-project.json` profile to the workspace root, then refresh.\n[Refresh](command:minecraftProjectDeploy.refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "minecraftProjectDeploy.refresh",
          "when": "view == minecraftProjectDeploy.project || view == minecraftProjectDeploy.actions || view == minecraftProjectDeploy.evidence",
          "group": "navigation"
        },
        {
          "command": "minecraftProjectDeploy.openProfile",
          "when": "view == minecraftProjectDeploy.project",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "mkdir -p artifacts && vsce package --allow-missing-repository --skip-license --out artifacts/appletree-minecraft-tools.vsix"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
